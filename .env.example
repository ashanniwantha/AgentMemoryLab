# Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL_NAME=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Databases
SQL_DB_PATH=src/data/chat_history.db
VECTOR_DB=src/data/chroma_db

# Token threshold for summarization (tokens)
SUMMARIZATION_TOKEN_THRESHOLD=8000

# How often (minutes) to run periodic reflection
REFLECTION_INTERVAL_MINUTES=5

# Log level (INFO, DEBUG, etc.)
LOG_LEVEL=INFO
